# Anthropic API (required for all AI endpoints)
ANTHROPIC_API_KEY=

# Upstash Redis (optional - fallback to in-memory cache if missing)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alpaca News API (required for historikk endpoint)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Analytics dashboard authentication (required for /api/analytics-dashboard)
ANALYTICS_SECRET=generate-random-secret-here

# SEC EDGAR API User-Agent (MANDATORY for /api/insider endpoint)
# Format: "AppName/Version contact@email.com"
# SEC requires a User-Agent header with contact info or returns 403
# Example: SEC_USER_AGENT="PULSE/1.0 your-email@example.com"
SEC_USER_AGENT=PULSE/1.0 contact@example.com

# Anthropic API (required for all AI endpoints)
ANTHROPIC_API_KEY=

# Upstash Redis (optional - fallback to in-memory cache if missing)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alpaca News API (required for historikk endpoint)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# OpenRouter API (required for ticker-multimodel endpoint)
OPENROUTER_API_KEY=

# Analytics dashboard authentication (required for /api/analytics-dashboard)
ANALYTICS_SECRET=generate-random-secret-here
